{
  "schemaVersion": 1,
  "id": "noxesium",
  "version": "${version}",
  "name": "Noxesium",
  "description": "Provides a framework for servers to customise client behavior.",
  "authors": [
    "Noxcrew"
  ],
  "contact": {
    "repo": "https://github.com/Noxcrew/noxesium",
    "homepage": "https://github.com/Noxcrew/noxesium",
    "issues": "https://github.com/Noxcrew/noxesium/issues"
  },
  "license": "LGPL-3.0-only",
  "icon": "assets/noxesium/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.noxcrew.noxesium.core.fabric.NoxesiumMod"
    ],
    "noxesium": [
      "com.noxcrew.noxesium.core.fabric.CommonFabricNoxesiumEntrypoint",
      "com.noxcrew.noxesium.core.fabric.mcc.MccNoxesiumEntrypoint"
    ],
    "modmenu": [
      "com.noxcrew.noxesium.core.fabric.integration.modmenu.ModMenuIntegration"
    ]
  },
  "accessWidener": "noxesium.classtweaker",
  "mixins": [
    "noxesium.mixins.json",
    "noxesium-sodium.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric-api": ">=0.144.0",
    "minecraft": ">=26.1"
  },
  "suggests": {
    "sodium": ">=0.8.7"
  }
}
